{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(claude-effort:*)",
      "Bash(claude-history:*)",
      "Bash(claude-hype:*)",
      "Bash(git *)"
